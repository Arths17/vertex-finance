#!/usr/bin/env bash
set -euo pipefail

staged_files=$(git diff --cached --name-only)

# Exclude .example files from security checks
staged_files_sensitive=$(echo "$staged_files" | grep -v '\.example$' || true)

if [ -z "$staged_files_sensitive" ]; then
  # All staged files are examples, skip checks
  exit 0
fi

staged_files_sensitive=$(git diff --cached --name-only --diff-filter=ACMR | grep -v '\.example$' || true)

if echo "$staged_files_sensitive" | grep -v '\.env\.example' | grep -Eq '(^|/)\.env($|/)'; then
  echo "❌ Commit blocked: .env files are staged."
  echo "   Move secrets to local .env files and keep them untracked."
  exit 1
fi

if echo "$staged_files_sensitive" | grep -Eq '\.(pem|p12|pfx|key)$'; then
  echo "❌ Commit blocked: key/certificate files are staged."
  echo "   Remove them from staging before committing."
  exit 1
fi

# Only check for secrets in non-example files
added_lines=$(git diff --cached --no-color -- $(echo "$staged_files_sensitive" | tr '\n' ' ') 2>/dev/null | grep '^+' | grep -v '^+++ ' || true)

if echo "$added_lines" | grep -Eq -- '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|ghp_[A-Za-z0-9]{36}|sk-[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}'; then
  echo "❌ Commit blocked: possible secret detected in staged changes."
  echo "   Remove/rotate the secret, then commit again."
  exit 1
fi

exit 0

